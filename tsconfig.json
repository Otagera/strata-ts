{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"types": ["bun-types"],
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"esModuleInterop": true,
		"isolatedModules": true
	}
}
